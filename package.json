{
  "name": "pd-slacker",
  "version": "1.0.0",
  "description": "Automated weekly on-call notifications from PagerDuty to Slack",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "job": "node dist/job.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:job": "ts-node src/job.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install",
    "docker:build": "docker build -t pd-slacker .",
    "docker:run": "docker run -p 8080:8080 pd-slacker",
    "docker:run:job": "docker run --env-file .env pd-slacker pnpm job"
  },
  "keywords": [
    "pagerduty",
    "slack",
    "on-call",
    "notifications",
    "automation",
    "scheduling"
  ],
  "author": "Roee Zolantz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/roeezolantz/pd-slacker.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^5.6.0",
    "@slack/web-api": "^7.0.4",
    "axios": "^1.6.5",
    "axios-retry": "^4.0.0",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.1",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "opossum": "^8.1.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/opossum": "^8.1.7",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^27.6.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "nock": "^13.5.0",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.12.1+sha512.e5a7e52a4183a02d5931057f7a0dbff9d5e9ce3161e33fa68ae392125b79282a8a8a470a51dfc8a0ed86221442eb2fb57019b0990ed24fab519bf0e1bc5ccfc4"
}
